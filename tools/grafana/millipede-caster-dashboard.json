{
  "__inputs": [
    {
      "name": "DS_MILLIPEDE",
      "label": "millipede-caster",
      "description": "Infinity JSON API datasource pointing at the caster /api/v1/ endpoints",
      "type": "datasource",
      "pluginId": "yesoreyeram-infinity-datasource",
      "typeLogoUrl": "public/plugins/yesoreyeram-infinity-datasource/img/logo.svg"
    }
  ],
  "__requires": [
    {
      "type": "datasource",
      "id": "yesoreyeram-infinity-datasource",
      "name": "Infinity",
      "version": "2.0.0"
    },
    {
      "type": "panel",
      "id": "stat",
      "name": "Stat",
      "version": ""
    },
    {
      "type": "panel",
      "id": "table",
      "name": "Table",
      "version": ""
    },
    {
      "type": "panel",
      "id": "bargauge",
      "name": "Bar gauge",
      "version": ""
    },
    {
      "type": "panel",
      "id": "timeseries",
      "name": "Time series",
      "version": ""
    }
  ],
  "annotations": { "list": [] },
  "description": "Dashboard for millipede-caster — monitors live sources, clients, RTCM message frequencies, and detects anomalies (degraded/missing messages).",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [
    {
      "title": "millipede-caster docs",
      "url": "https://github.com/pbeyssac/millipede-caster",
      "type": "link",
      "icon": "external link",
      "tags": []
    }
  ],
  "liveNow": false,
  "panels": [
    {
      "datasource": { "type": "yesoreyeram-infinity-datasource", "uid": "${DS_MILLIPEDE}" },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 50 },
              { "color": "red", "value": 200 }
            ]
          },
          "mappings": [],
          "color": { "mode": "thresholds" }
        },
        "overrides": []
      },
      "gridPos": { "h": 5, "w": 4, "x": 0, "y": 0 },
      "id": 1,
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto",
        "textMode": "auto",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "orientation": "auto"
      },
      "pluginVersion": "10.0.0",
      "targets": [
        {
          "datasource": { "type": "yesoreyeram-infinity-datasource", "uid": "${DS_MILLIPEDE}" },
          "refId": "A",
          "type": "json",
          "options": {
            "format": "table",
            "root_selector": "",
            "source": "url",
            "url": "$base_url/adm/api/v1/net",
            "url_options": {
              "method": "GET",
              "data": "",
              "headers": [
                { "key": "Authorization", "value": "$auth_header" }
              ]
            }
          },
          "columns": [
            { "selector": "type", "type": "string" }
          ]
        }
      ],
      "title": "Total sessions",
      "transformations": [
        {
          "id": "groupBy",
          "options": {
            "fields": {
              "type": { "aggregations": ["count"], "operation": "aggregate" }
            }
          }
        }
      ],
      "type": "stat"
    },
    {
      "datasource": { "type": "yesoreyeram-infinity-datasource", "uid": "${DS_MILLIPEDE}" },
      "gridPos": { "h": 5, "w": 20, "x": 4, "y": 0 },
      "id": 2,
      "options": {
        "showHeader": true,
        "cellHeight": "sm",
        "footer": { "show": false }
      },
      "targets": [
        {
          "datasource": { "type": "yesoreyeram-infinity-datasource", "uid": "${DS_MILLIPEDE}" },
          "refId": "A",
          "type": "json",
          "options": {
            "format": "table",
            "source": "url",
            "url": "$base_url/adm/api/v1/net",
            "url_options": {
              "method": "GET",
              "headers": [
                { "key": "Authorization", "value": "$auth_header" }
              ]
            }
          }
        }
      ],
      "title": "Live sessions",
      "transformations": [
        { "id": "organize", "options": {
          "excludeByName": { "wildcard": true, "remote": true, "local": true },
          "renameByName": {
            "id": "ID",
            "type": "Type",
            "mountpoint": "Mountpoint",
            "ip": "Remote IP",
            "port": "Port",
            "received_bytes": "Bytes in",
            "sent_bytes": "Bytes out",
            "user_agent": "User-Agent",
            "start": "Started"
          }
        }}
      ],
      "type": "table"
    },
    {
      "datasource": { "type": "yesoreyeram-infinity-datasource", "uid": "${DS_MILLIPEDE}" },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.5 },
              { "color": "green", "value": 0.9 }
            ]
          },
          "mappings": [],
          "color": { "mode": "thresholds" },
          "unit": "Hz"
        },
        "overrides": []
      },
      "gridPos": { "h": 12, "w": 24, "x": 0, "y": 5 },
      "id": 3,
      "options": {
        "orientation": "horizontal",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "showUnfilled": true
      },
      "targets": [
        {
          "datasource": { "type": "yesoreyeram-infinity-datasource", "uid": "${DS_MILLIPEDE}" },
          "refId": "A",
          "type": "json",
          "options": {
            "format": "table",
            "source": "url",
            "url": "$base_url/adm/api/v1/rtcm/frequencies",
            "url_options": {
              "method": "GET",
              "headers": [
                { "key": "Authorization", "value": "$auth_header" }
              ]
            }
          }
        }
      ],
      "title": "RTCM message rates by mountpoint / type",
      "transformations": [
        {
          "id": "extractFields",
          "options": { "format": "json", "source": "" }
        }
      ],
      "type": "bargauge"
    },
    {
      "datasource": { "type": "yesoreyeram-infinity-datasource", "uid": "${DS_MILLIPEDE}" },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "auto",
            "cellOptions": { "type": "auto" },
            "inspect": false
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 2 }
            ]
          },
          "mappings": [],
          "color": { "mode": "thresholds" }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "state" },
            "properties": [
              {
                "id": "custom.cellOptions",
                "value": { "type": "color-background", "mode": "basic" }
              }
            ]
          }
        ]
      },
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 17 },
      "id": 4,
      "options": {
        "showHeader": true,
        "cellHeight": "sm",
        "footer": { "show": false, "reducer": ["sum"] }
      },
      "targets": [
        {
          "datasource": { "type": "yesoreyeram-infinity-datasource", "uid": "${DS_MILLIPEDE}" },
          "refId": "A",
          "type": "json",
          "options": {
            "format": "table",
            "source": "url",
            "url": "$base_url/adm/api/v1/rtcm/frequencies",
            "url_options": {
              "method": "GET",
              "headers": [
                { "key": "Authorization", "value": "$auth_header" }
              ]
            }
          }
        }
      ],
      "title": "RTCM anomaly detector (low/missing messages)",
      "transformations": [
        {
          "id": "extractFields",
          "options": { "format": "json" }
        }
      ],
      "type": "table"
    }
  ],
  "refresh": "5s",
  "schemaVersion": 38,
  "style": "dark",
  "tags": ["gnss", "ntrip", "rtcm", "millipede"],
  "templating": {
    "list": [
      {
        "name": "base_url",
        "type": "constant",
        "label": "Caster URL",
        "query": "http://localhost:2101",
        "description": "Base URL of the millipede-caster (without trailing slash)",
        "current": { "text": "http://localhost:2101", "value": "http://localhost:2101" }
      },
      {
        "name": "auth_header",
        "type": "constant",
        "label": "Auth header",
        "query": "Basic YWRtaW46YWRtaW4=",
        "description": "HTTP Authorization header value. For Basic auth, base64 of 'user:password'. For Bearer token auth, use 'Bearer <token>'.",
        "current": { "text": "Basic YWRtaW46YWRtaW4=", "value": "Basic YWRtaW46YWRtaW4=" }
      }
    ]
  },
  "time": { "from": "now-15m", "to": "now" },
  "timepicker": {},
  "timezone": "",
  "title": "millipede-caster",
  "uid": "millipede-caster",
  "version": 1,
  "weekStart": ""
}
